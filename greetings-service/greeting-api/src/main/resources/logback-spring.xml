<configuration>

    <property name="LOGS" value="app/logs" />
    <property name="APP_NAME" value="greeting-api" />

    <!-- ===================== -->
    <!-- DEV: Console Appender -->
    <!-- ===================== -->
    <appender name="CONSOLE"
              class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %d{HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- ================================ -->
    <!-- PROD: Rolling File Appender      -->
    <!-- Rotates every 72 hours or 50MB  -->
    <!-- Keeps 30 days of archived logs  -->
    <!-- ================================ -->
    <appender name="ROLLING_FILE"
              class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOGS}/${APP_NAME}.log</file>

        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>

    <rollingPolicy
    	class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">

      <fileNamePattern>
        logs/archive/application-%d{yyyy-MM-dd}.%i.log.gz
      </fileNamePattern>
    	<maxFileSize>10MB</maxFileSize>
    	<maxHistory>30</maxHistory>
    	<totalSizeCap>1GB</totalSizeCap>

    </rollingPolicy>

        <!-- Only ship WARN and above to file in prod -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
    </appender>

    <!-- ===================== -->
    <!-- DEV profile config    -->
    <!-- ===================== -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
        <!-- Code logs at DEBUG in dev -->
        <logger name="com.example.greeting" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE" />
        </logger>
        <!-- Keep framework noise down -->
        <logger name="org.springframework" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE" />
        </logger>
    </springProfile>

    <!-- ===================== -->
    <!-- PROD profile config   -->
    <!-- ===================== -->
    <springProfile name="prod">
        <root level="WARN">
            <appender-ref ref="ROLLING_FILE" />
        </root>
        <!-- Your code logs at INFO in prod -->
        <logger name="com.example.greeting" level="INFO" additivity="false">
            <appender-ref ref="ROLLING_FILE" />
        </logger>
        <!-- Suppress framework logs entirely in prod -->
        <logger name="org.springframework" level="WARN" additivity="false">
            <appender-ref ref="ROLLING_FILE" />
        </logger>
    </springProfile>

<springProfile name="!dev &amp; !prod">
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>
</springProfile>

</configuration>
